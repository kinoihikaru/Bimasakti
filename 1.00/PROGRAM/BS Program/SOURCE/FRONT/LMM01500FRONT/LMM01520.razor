@inherits R_Page
@using LMM01500COMMON
@using LMM01500MODEL

<R_StackLayout Class="mb-4">
    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_Label Class="fw-bold" FontSize="11">Invoice Group</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="2">
            <R_TextBox @bind-Value="@_InvPinalty_viewModel.InvGrpCode"
                       Enabled="false">
            </R_TextBox>
        </R_ItemLayout>
        <R_ItemLayout xs="4">
            <R_TextBox @bind-Value="@_InvPinalty_viewModel.InvGrpName"
                       Enabled="false">
            </R_TextBox>
        </R_ItemLayout>
    </R_StackLayout>
</R_StackLayout>

<R_StackLayout>
    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_CheckBox @bind-Value="@_InvPinalty_viewModel.Data.LPENALTY"
                        R_ConductorSource="@_InvPinalty_conductorRef"
                        R_EnableEdit>
            </R_CheckBox>
        </R_ItemLayout>
        <R_ItemLayout xs="1">
            <R_Label>Enable Pinalty</R_Label>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="2">
            <R_Label>Additional Id</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_TextBox @bind-Value="@_InvPinalty_viewModel.Data.CPENALTY_ADD_ID"
                       R_ConductorSource="@_InvPinalty_conductorRef"
                       Enabled="false"></R_TextBox>
        </R_ItemLayout>

        <R_ItemLayout xs="6">
            <R_TextBox @bind-Value="@_InvPinalty_viewModel.Data.CCHARGES_NAME"
                       R_ConductorSource="@_InvPinalty_conductorRef"
                       Enabled="false"></R_TextBox>
        </R_ItemLayout>
        <R_ItemLayout xs="1">
            <R_Lookup R_ConductorSource="@_InvPinalty_conductorRef" R_Before_Open_Lookup="@Pinalty_OtherCharges_Before_Open_Lookup" R_After_Open_Lookup="@Pinalty_OtherCharges_After_Open_Lookup" R_EnableAdd R_EnableEdit>...</R_Lookup>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row="true">
        <R_StackLayout Class="col-1">
            <R_Label>Penalty Type *</R_Label>
        </R_StackLayout>
        <R_StackLayout Class="col-2">
            <R_RadioGroup R_ConductorSource="@_InvPinalty_conductorRef"
                          Class="d-block" Data="@_InvPinalty_viewModel.RadioPinaltyType"
                          @bind-Value="@_InvPinalty_viewModel.Data.CPENALTY_TYPE"
                          ValueField="@nameof(RadioButton.Id)"
                          TextField="@nameof(RadioButton.Text)"
                            R_EnableEdit OnChanged="@Pinalty_RadioButtonOnChange"></R_RadioGroup>
            </R_StackLayout>
            <R_StackLayout Class="col-2">
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.MonthlyAmmountValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@MonthlyAmmountEnable"></R_NumericTextBox>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2" Style="display: inline-block">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.MonthlyPercentageValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@MonthlyPercentageEnable"></R_NumericTextBox>
                </R_ItemLayout>
                <R_Label>%</R_Label>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.DailyAmmountValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@DailyAmmountEnable"></R_NumericTextBox>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.DailyPercentageValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@DailyPercentageEnable"></R_NumericTextBox>

                </R_ItemLayout>
                <R_Label>%</R_Label>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.OneTimeAmmountValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@OneTimeAmmountEnable"></R_NumericTextBox>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.OneTimePercentageValue"
                                      R_ConductorSource="@_InvPinalty_conductorRef"
                                      Enabled="@OneTimePercentageEnable"></R_NumericTextBox>
                </R_ItemLayout>
                <R_Label>%</R_Label>
            </R_StackLayout>
            </R_StackLayout>
            <R_StackLayout Class="col-6">
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_Label></R_Label>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Class="ms-3" Row="true">
                <R_ItemLayout xs="2">
                    <R_Label>Calculation base on</R_Label>
                </R_ItemLayout>
                <R_ItemLayout xs="9">
                    <R_RadioGroup Data="@_InvPinalty_viewModel.RadioPinaltyTypeCalcBaseonMonth"
                                  @bind-Value="@_InvPinalty_viewModel.CalcBaseonMonthValue"
                                  ValueField="@nameof(RadioButton.Id)"
                                  TextField="@nameof(RadioButton.Text)"
                                  R_ConductorSource="@_InvPinalty_conductorRef"
                                  Enabled="@CalcBaseonMonthEnable"></R_RadioGroup>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Row="true">
                <R_ItemLayout xs="2">
                    <R_Label></R_Label>
                </R_ItemLayout>
            </R_StackLayout>
            <R_StackLayout Class="ms-3" Row="true">
                <R_ItemLayout xs="2">
                    <R_Label>Calculation base on</R_Label>
                </R_ItemLayout>
                <R_ItemLayout xs="9">
                    <R_RadioGroup Data="@_InvPinalty_viewModel.RadioPinaltyTypeCalcBaseonDays"
                                  @bind-Value="@_InvPinalty_viewModel.CalcBaseonDaysValue"
                                  ValueField="@nameof(RadioButton.Id)"
                                  TextField="@nameof(RadioButton.Text)"
                                  R_ConductorSource="@_InvPinalty_conductorRef"
                                  Enabled="@CalcBaseonDaysEnable"></R_RadioGroup>
                </R_ItemLayout>
            </R_StackLayout>
            </R_StackLayout>
            </R_StackLayout>

            <R_StackLayout Row>
        <R_ItemLayout xs="2">
            <R_Label>Rounded</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="2">
            <R_ComboBox R_ConductorSource="@_InvPinalty_conductorRef"
                        Data="@_InvPinalty_viewModel.RadioRounded"
                        @bind-Value="_InvPinalty_viewModel.Data.IROUNDED"
                        ValueField="@nameof(RadioButtonInt.Id)"
                        TextField="@nameof(RadioButtonInt.Text)"
                        R_EnableEdit="false">
            </R_ComboBox>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="2">
            <R_Label>Cut of Date By</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="2">
            <R_RadioGroup Data="@_InvPinalty_viewModel.RadioCutOfDate"
                          @bind-Value="_InvPinalty_viewModel.Data.CCUTOFDATE_BY"
                          ValueField="@nameof(RadioButton.Id)"
                          TextField="@nameof(RadioButton.Text)"
                          R_ConductorSource="@_InvPinalty_conductorRef">
            </R_RadioGroup>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="2">
            <R_Label>Grace Priod</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="1">
            <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.Data.IGRACE_PERIOD"
                              R_ConductorSource="@_InvPinalty_conductorRef"
                              R_EnableEdit="true"></R_NumericTextBox>
        </R_ItemLayout>
        <R_ItemLayout xs="1">
            <R_Label>days</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_Label>Penalty Fee Start from</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="5">
            <R_RadioGroup Data="@_InvPinalty_viewModel.RadioPinaltyFeeStartFrom"
                          @bind-Value="_InvPinalty_viewModel.Data.CPENALTY_FEE_START_FROM"
                          ValueField="@nameof(RadioButton.Id)"
                          TextField="@nameof(RadioButton.Text)"
                          R_ConductorSource="@_InvPinalty_conductorRef">
            </R_RadioGroup>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="2">
            <R_Label>Exclude Spesial Day</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_CheckBox R_ConductorSource="@_InvPinalty_conductorRef"
                        @bind-Value="@_InvPinalty_viewModel.Data.LEXCLUDE_SPECIAL_DAY_HOLIDAY"
                        R_EnableEdit="true">Holiday</R_CheckBox>
            <R_Label>Holiday</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2" Class="d-inline">
            <R_CheckBox R_ConductorSource="@_InvPinalty_conductorRef"
                        @bind-Value="@_InvPinalty_viewModel.Data.LEXCLUDE_SPECIAL_DAY_SATURDAY"
                        R_EnableEdit="true"></R_CheckBox>
            <R_Label Class="ms-2">Saturday</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2" Class="d-inline">
            <R_CheckBox R_ConductorSource="@_InvPinalty_conductorRef"
                        @bind-Value="@_InvPinalty_viewModel.Data.LEXCLUDE_SPECIAL_DAY_SUNDAY"
                        R_EnableEdit="true"></R_CheckBox>
            <R_Label Class="ms-2">Sunday</R_Label>
        </R_ItemLayout>
    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_CheckBox R_ConductorSource="@_InvPinalty_conductorRef"
                        OnChanged="@Pinalty_OnCheckedMinAmmount" @bind-Value="@_InvPinalty_viewModel.MinPinaltyAmount"
                        R_EnableEdit="true"></R_CheckBox>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_Label>Penalty Fee Start from</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.Data.NMIN_PENALTY_AMOUNT"
                              R_ConductorSource="@_InvPinalty_conductorRef"
                              Enabled="@MinAmmountEnable"></R_NumericTextBox>
        </R_ItemLayout>

    </R_StackLayout>

    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_CheckBox R_ConductorSource="@_InvPinalty_conductorRef"
                        OnChanged="@Pinalty_OnCheckedMaxAmmount" @bind-Value="@_InvPinalty_viewModel.MaxPinaltyAmount"
                        R_EnableEdit="true"></R_CheckBox>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_Label>Penalty Fee Start from</R_Label>
        </R_ItemLayout>
        <R_ItemLayout xs="2">
            <R_NumericTextBox @bind-Value="@_InvPinalty_viewModel.Data.NMAX_PENALTY_AMOUNT"
                              R_ConductorSource="@_InvPinalty_conductorRef"
                              Enabled="@MaxAmmountEnable"></R_NumericTextBox>
        </R_ItemLayout>

    </R_StackLayout>

    <R_StackLayout Row="true">
        <R_StackLayout Class="col-1">
            <R_EditButton R_Conductor="@_InvPinalty_conductorRef"></R_EditButton>
        </R_StackLayout>
        <R_StackLayout Class="col-7">
            <R_StackLayout Row="true" Class="justify-content-end">
                <R_ItemLayout xs="1">
                    <R_CancelButton R_Conductor="@_InvPinalty_conductorRef"></R_CancelButton>
                </R_ItemLayout>
                <R_ItemLayout xs="1">
                    <R_SaveButton R_Conductor="@_InvPinalty_conductorRef"></R_SaveButton>
                </R_ItemLayout>
            </R_StackLayout>
        </R_StackLayout>

    </R_StackLayout>

</R_StackLayout>

<R_Conductor @ref="@_InvPinalty_conductorRef"
             R_ViewModel="@_InvPinalty_viewModel"
             R_IsHeader="true"
             R_ServiceGetRecord="@Pinalty_ServiceGetRecord"
             R_ServiceSave="@Pinalty_ServiceSave"
             R_Validation="@Pinalty_Validation">
</R_Conductor>
