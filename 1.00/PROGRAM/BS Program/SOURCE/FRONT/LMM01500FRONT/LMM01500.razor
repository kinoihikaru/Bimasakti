@page "/LMM01500"
@inherits R_Page
@using LMM01500COMMON
@using LMM01500MODEL

<R_StackLayout Class="mb-4 mt-3">
    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_Label FontColor="Red" Class="fw-bold ms-3" FontSize="15">Property</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="2">
            <R_DropDownList Data="@_Genereal_viewModel.PropertyList"
                            @bind-Value="_Genereal_viewModel.PropertyValueContext"
                            ValueField="@nameof(LMM01500DTOPropety.CPROPERTY_ID)"
                            TextField="@nameof(LMM01500DTOPropety.CPROPERTY_NAME)"
                            R_ConductorSource="@_Genereal_conductorRef" OnChanged="@PropertyDropdown_OnChange"
                            
                           >
            </R_DropDownList>
        </R_ItemLayout>
    </R_StackLayout>
</R_StackLayout>

<R_TabStrip OnActiveTabIndexChanged="@General_OnActiveTabIndexChanged" >

    <R_TabStripTab Title="General Info" Id="General" >

        <R_TabStrip OnActiveTabIndexChanged="@BankAccount_OnActiveTabIndexChanged">

            <R_TabStripTab  Title="General Info">
                <R_StackLayout Spacing="3" Class="mb-4 mt-4" Row="true">

                    <R_StackLayout Class="col-2">
                        <R_Grid @ref="@_Genereal_gridRef"
                                DataSource="@_Genereal_viewModel.InvoinceGroupGrid"
                                R_ConductorSource="@_Genereal_conductorRef"
                                R_GridType="@R_eGridType.Navigator"
                                R_ServiceGetListRecord="@GroupGrid_ServiceGetListRecord">
                            <R_GridColumns>
                                <R_GridNumericColumn FieldName="CINVGRP_CODE_NAME" HeaderText="Invoice Group"></R_GridNumericColumn>
                            </R_GridColumns>
                        </R_Grid>
                    </R_StackLayout>

                    <R_StackLayout Class="col-7">

                        <R_StackLayout Row="true" Class="justify-content-end">
                            <R_ItemLayout xs="1">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LACTIVE"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            Enabled="false">
                                </R_CheckBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="1">
                                <R_Label>Active</R_Label>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Invoice Group*</R_Label>
                            </R_ItemLayout>

                            <R_ItemLayout xs="2">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_CODE"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           R_EnableAdd="true"
                                           R_EnableEdit="false">
                                </R_TextBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="7">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_NAME"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           R_EnableAdd="true"
                                           R_EnableEdit="true">
                                </R_TextBox>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Process Seq</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2">
                                <R_NumericTextBox @bind-Value="@_Genereal_viewModel.Data.CSEQUENCEInt"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           R_EnableAdd="true" R_EnableEdit="true"></R_NumericTextBox>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Invoice Due Mode</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="8">
                                <R_RadioGroup Data="@_Genereal_viewModel.RadioInvDMList"
                                              @bind-Value="@_Genereal_viewModel.Data.CINVOICE_DUE_MODE"
                                              ValueField="@nameof(RadioButton.Id)"
                                              TextField="@nameof(RadioButton.Text)"
                                              R_ConductorSource="@_Genereal_conductorRef"
                                              R_EnableAdd="true" R_EnableEdit="true" OnChanged="@InvDue_OnChanged"></R_RadioGroup>
                            </R_ItemLayout>
                        </R_StackLayout>
                        <R_GroupBox Title="Invoice Group Mode">
                            <R_StackLayout Row="true">
                                <R_ItemLayout xs="3">
                                    <R_RadioGroup Class="d-block" Data="@_Genereal_viewModel.RadioInvGrpMode"
                                                  @bind-Value="@_Genereal_viewModel.Data.CINVOICE_GROUP_MODE"
                                                  ValueField="@nameof(RadioButton.Id)"
                                                  TextField="@nameof(RadioButton.Text)"
                                                  R_ConductorSource="@_Genereal_conductorRef"
                                                  Enabled="@InvGrpModeEnable" OnChanged="@InvGrp_OnChanged"></R_RadioGroup>
                                </R_ItemLayout>
                                <R_ItemLayout Class="col-1">
                                    <R_ItemLayout Class="d-block">
                                        <R_NumericTextBox @bind-Value="@_Genereal_viewModel.Data.IDUE_DAYS"
                                                          R_ConductorSource="@_Genereal_conductorRef"
                                                          Enabled="@IDueDaysEnable"></R_NumericTextBox>
                                        <R_NumericTextBox @bind-Value="@_Genereal_viewModel.Data.IFIXED_DUE_DATE"
                                                          R_ConductorSource="@_Genereal_conductorRef"
                                                          Enabled="@IFixDueDateEnable"></R_NumericTextBox>
                                    </R_ItemLayout>
                                    <R_ItemLayout Style="display: inline-flex; width:max-content">
                                        <R_Label Class="m-2">Limit Invoice Date*</R_Label>
                                        <R_NumericTextBox Width="5rem" @bind-Value="@_Genereal_viewModel.Data.ILIMIT_INVOICE_DATE"
                                                          R_ConductorSource="@_Genereal_conductorRef"
                                                          Enabled="@ILimitDueDateEnable"></R_NumericTextBox>
                                        <R_Label Class="m-2">Less Than Equal Limit*</R_Label>
                                        <R_NumericTextBox Width="5rem" @bind-Value="@_Genereal_viewModel.Data.IBEFORE_LIMIT_INVOICE_DATE"
                                                          R_ConductorSource="@_Genereal_conductorRef"
                                                          Enabled="@IBeforeLimitEnable"></R_NumericTextBox>
                                        <R_Label Class="m-2">After Limit*</R_Label>
                                        <R_NumericTextBox Width="5rem" @bind-Value="@_Genereal_viewModel.Data.IAFTER_LIMIT_INVOICE_DATE"
                                                          R_ConductorSource="@_Genereal_conductorRef"
                                                          Enabled="@IAfterLimitEnable"></R_NumericTextBox>
                                    </R_ItemLayout>

                                </R_ItemLayout>
                                <R_ItemLayout xs="2">
                                    <R_Label Class="d-block">Days</R_Label>
                                    <R_Label Class="d-block">Next Month</R_Label>
                                </R_ItemLayout>
                            </R_StackLayout>

                        </R_GroupBox>
                        
                        <R_StackLayout Row="true" Class="d-inline">
                            <R_ItemLayout xs="2">
                                <R_Label>Due Date Tolarance</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LDUE_DATE_TOLERANCE_HOLIDAY"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true">Holiday</R_CheckBox>
                                <R_Label>Holiday</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2" Class="d-inline">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LDUE_DATE_TOLERANCE_SATURDAY"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true"></R_CheckBox>
                                <R_Label Class="ms-2">Saturday</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2" Class="d-inline">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LDUE_DATE_TOLERANCE_SUNDAY"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true"></R_CheckBox>
                                <R_Label Class="ms-2">Sunday</R_Label>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2" Class="d-inline">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LUSE_STAMP"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true"></R_CheckBox>
                                <R_Label Class="ms-2">Use Stamp</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2">
                                <R_Label>Additional Id*</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CSTAMP_ADD_ID"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           Enabled="false"></R_TextBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="1">
                                <R_Lookup R_ConductorSource="_Genereal_conductorRef" R_Before_Open_Lookup="@OtherCharges_Before_Open_Lookup" R_After_Open_Lookup="@OtherCharges_After_Open_Lookup" Enabled="_Genereal_viewModel.Data.LUSE_STAMP">...</R_Lookup>
                            </R_ItemLayout>
                            <R_ItemLayout xs="4">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CCHARGES_NAME"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           Enabled="false"></R_TextBox>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Description</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="9">
                                <R_TextArea @bind-Value="@_Genereal_viewModel.Data.CDESCRIPTION"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true"></R_TextArea>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="1">
                                <R_CheckBox @bind-Value="@_Genereal_viewModel.Data.LBY_DEPARTMENT"
                                            R_ConductorSource="@_Genereal_conductorRef"
                                            R_EnableAdd="true" R_EnableEdit="true"></R_CheckBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="2">
                                <R_Label Class="ms-2">By Departement</R_Label>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_GroupBox Title="All Department">
                            <R_StackLayout Row="true">
                                <R_ItemLayout xs="2">
                                    <R_Label>Invoice Template*</R_Label>
                                </R_ItemLayout>
                                <R_ItemLayout xs="8">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVOICE_TEMPLATE"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                                <R_ItemLayout xs="1">
                                    <R_InputFile Enabled="@_Genereal_viewModel.Data.LBY_DEPARTMENT" >...</R_InputFile>
                                </R_ItemLayout>
                            </R_StackLayout>

                            <R_StackLayout Row="true">
                                <R_Label FontColor="Red" Class="fw-bold" FontSize="13">Bank Receipt Info</R_Label>
                            </R_StackLayout>

                            <R_StackLayout Row="true">
                                <R_ItemLayout xs="2">
                                    <R_Label>Department*</R_Label>
                                </R_ItemLayout>
                                <R_ItemLayout xs="2">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CDEPT_CODE"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                                <R_ItemLayout xs="1">
                                    <R_Lookup Enabled="@_Genereal_viewModel.Data.LBY_DEPARTMENT" R_Before_Open_Lookup="@Department_Before_Open_Lookup" R_After_Open_Lookup="@General_Department_After_Open_Lookup">...</R_Lookup>
                                </R_ItemLayout>
                                <R_ItemLayout xs="6">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CDEPT_NAME"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                            </R_StackLayout>

                            <R_StackLayout Row="true">
                                <R_ItemLayout xs="2">
                                    <R_Label>Bank*</R_Label>
                                </R_ItemLayout>
                                <R_ItemLayout xs="2">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CBANK_CODE"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                                <R_ItemLayout xs="1">
                                    <R_Lookup Enabled="@_Genereal_viewModel.Data.LBY_DEPARTMENT" R_Before_Open_Lookup="@Bank_Before_Open_Lookup" R_After_Open_Lookup="@General_Bank_After_Open_Lookup">...</R_Lookup>
                                </R_ItemLayout>
                                <R_ItemLayout xs="6">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CCB_NAME"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                            </R_StackLayout>

                            <R_StackLayout Row="true">
                                <R_ItemLayout xs="2">
                                    <R_Label>Bank Account*</R_Label>
                                </R_ItemLayout>
                                <R_ItemLayout xs="6">
                                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CBANK_ACCOUNT"
                                               R_ConductorSource="@_Genereal_conductorRef"
                                               Enabled="false"></R_TextBox>
                                </R_ItemLayout>
                                <R_ItemLayout xs="1">
                                    <R_Lookup Enabled="@GeneralButtonEnable" R_Before_Open_Lookup="@BankAccount_Before_Open_Lookup" R_After_Open_Lookup="@BankAccount_After_Open_Lookup">...</R_Lookup>
                                </R_ItemLayout>
                            </R_StackLayout>
                        </R_GroupBox>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Updated By</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="4">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CUPDATE_BY"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           Enabled="false"></R_TextBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="1">
                                <R_Label>Date</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="3">
                                <R_DateTimePicker @bind-Value="@_Genereal_viewModel.Data.DUPDATE_DATE"
                                                  R_ConductorSource="@_Genereal_conductorRef"
                                                  Enabled="false"></R_DateTimePicker>
                            </R_ItemLayout>
                        </R_StackLayout>

                        <R_StackLayout Row="true">
                            <R_ItemLayout xs="2">
                                <R_Label>Created By</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="4">
                                <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CCREATE_BY"
                                           R_ConductorSource="@_Genereal_conductorRef"
                                           Enabled="false"></R_TextBox>
                            </R_ItemLayout>
                            <R_ItemLayout xs="1">
                                <R_Label>Date</R_Label>
                            </R_ItemLayout>
                            <R_ItemLayout xs="3">
                                <R_DateTimePicker @bind-Value="@_Genereal_viewModel.Data.DCREATE_DATE"
                                                  R_ConductorSource="@_Genereal_conductorRef"
                                                  Enabled="false"></R_DateTimePicker>
                            </R_ItemLayout>
                        </R_StackLayout>


                    </R_StackLayout>

                </R_StackLayout>

                <R_StackLayout Row Class="justify-content-around">
                    <R_ItemLayout xs="1">
                        <R_AddButton R_Conductor="@_Genereal_conductorRef"></R_AddButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_EditButton R_Conductor="@_Genereal_conductorRef"></R_EditButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_DeleteButton R_Conductor="@_Genereal_conductorRef"></R_DeleteButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_Popup R_Before_Open_Popup="@R_Before_Open_Popup_ActivateInactive" R_After_Open_Popup="@R_After_Open_Popup_ActivateInactive" Enabled="@R_ActiveInActiveBtnEnable">@_Genereal_lcLabel</R_Popup>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_CancelButton R_Conductor="@_Genereal_conductorRef"></R_CancelButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_SaveButton R_Conductor="@_Genereal_conductorRef"></R_SaveButton>
                    </R_ItemLayout>
                </R_StackLayout>

                <R_Conductor @ref="@_Genereal_conductorRef"
                             R_ViewModel="@_Genereal_viewModel"
                             R_IsHeader="true"
                             R_ServiceGetRecord="@R_ServiceGetRecord"
                             R_ServiceSave="@R_ServiceSave"
                             R_ServiceDelete="@R_ServiceDelete"
                             R_Validation="@R_Validation"
                             R_Display="@R_Display"
                             R_CheckAdd="@R_CheckAdd"
                             R_SetAdd="@R_SetAdd"
                             R_SetEdit="@R_SetEdit"
                             R_SetHasData="@R_SetHasData"
                             >
                </R_Conductor>

            </R_TabStripTab>

            <R_TabStripTab Title="Template and Bank Account" >
                <R_StackLayout Class="mb-4">
                    <R_StackLayout Row>
                        <R_ItemLayout xs="2">
                            <R_Label Class="fw-bold" FontSize="11">Invoice Group</R_Label>
                        </R_ItemLayout>

                        <R_ItemLayout xs="2">
                            <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_CODE"
                                       R_ConductorSource="@_Genereal_conductorRef"
                                       Enabled="false">
                            </R_TextBox>
                        </R_ItemLayout>
                        <R_ItemLayout xs="5">
                            <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_NAME"
                                       R_ConductorSource="@_Genereal_conductorRef"
                                       Enabled="false">
                            </R_TextBox>
                        </R_ItemLayout>
                    </R_StackLayout>
                </R_StackLayout>

                <R_StackLayout Class="mb-3">
                    <R_Grid @ref="@_BankAccount_gridRef"
                            DataSource="@_BankAccount_viewModel.TemplateBankAccountGrid"
                            R_ConductorSource="@_BankAccount_conductorRef"
                            R_GridType="@R_eGridType.Navigator"
                            Pageable="true"
                            R_ServiceGetListRecord="@BankAccount_ServiceGetListRecord">
                        <R_GridColumns>
                            <R_GridNumericColumn FieldName="CDEPT_NAME" HeaderText="Department"></R_GridNumericColumn>
                            <R_GridTextColumn FieldName="CBANK_NAME" HeaderText="Bank"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="CBANK_ACCOUNT" HeaderText="Bank Account"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="CBANK_ACCOUNT" HeaderText="Invoice Template"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="CUPDATE_BY" HeaderText="Update By"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="DUPDATE_DATE" HeaderText="Update Date"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="CCREATE_BY" HeaderText="Created By"></R_GridTextColumn>
                            <R_GridTextColumn FieldName="DCREATE_DATE" HeaderText="Created Date"></R_GridTextColumn>
                        </R_GridColumns>
                    </R_Grid>
                </R_StackLayout>


                <R_StackLayout>
                    <R_StackLayout Row>
                        <R_ItemLayout xs="2">
                            <R_Label>Department</R_Label>
                        </R_ItemLayout>
                        <R_ItemLayout xs="2">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CDEPT_CODE"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                        <R_ItemLayout xs="1">
                            <R_Lookup R_ConductorSource="@_BankAccount_conductorRef" R_Before_Open_Lookup="@Department_Before_Open_Lookup" R_After_Open_Lookup="@BankAccount_Department_After_Open_Lookup" R_EnableAdd R_EnableEdit>...</R_Lookup>
                        </R_ItemLayout>
                        <R_ItemLayout xs="6">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CDEPT_NAME"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                    </R_StackLayout>

                    <R_StackLayout Row>
                        <R_ItemLayout xs="2">
                            <R_Label Class="ms-2">Invoice Template*</R_Label>
                        </R_ItemLayout>
                        <R_ItemLayout xs="6">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CINVOICE_TEMPLATE"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                        <R_ItemLayout xs="2">
                            <R_InputFile R_ConductorSource="@_BankAccount_conductorRef" R_EnableAdd R_EnableEdit>...</R_InputFile>
                        </R_ItemLayout>
                    </R_StackLayout>

                    <R_StackLayout Row>
                        <R_Label FontColor="Red" Class="fw-bold" FontSize="13">Bank Receipt Info</R_Label>
                    </R_StackLayout>

                    <R_StackLayout Row>
                        <R_ItemLayout xs="2">
                            <R_Label>Bank*</R_Label>
                        </R_ItemLayout>
                        <R_ItemLayout xs="3">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CBANK_CODE"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                        <R_ItemLayout xs="1">
                            <R_Lookup R_ConductorSource="@_BankAccount_conductorRef" R_Before_Open_Lookup="@BankAccount_Bank_Before_Open_Lookup" R_After_Open_Lookup="@BankAccount_Bank_After_Open_Lookup" R_EnableAdd R_EnableEdit>...</R_Lookup>
                        </R_ItemLayout>
                        <R_ItemLayout xs="6">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CBANK_NAME"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                    </R_StackLayout>

                    <R_StackLayout Row>
                        <R_ItemLayout xs="2">
                            <R_Label>Bank Account*</R_Label>
                        </R_ItemLayout>
                        <R_ItemLayout xs="3">
                            <R_TextBox @bind-Value="@_BankAccount_viewModel.Data.CBANK_ACCOUNT"
                                       R_ConductorSource="@_BankAccount_conductorRef"
                                       Enabled="false"></R_TextBox>
                        </R_ItemLayout>
                        <R_ItemLayout xs="1">
                            <R_Lookup Enabled="@BankAccountButtonEnable" R_Before_Open_Lookup="@BankAccount_BankAccount_Before_Open_Lookup" R_After_Open_Lookup="@BankAccount_BankAccount_After_Open_Lookup">...</R_Lookup>
                        </R_ItemLayout>
                    </R_StackLayout>

                </R_StackLayout>


                <R_StackLayout Row Class="d-flex justify-content-between">

                    <R_ItemLayout xs="1">
                        <R_AddButton R_Conductor="@_BankAccount_conductorRef"></R_AddButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_EditButton R_Conductor="@_BankAccount_conductorRef"></R_EditButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_DeleteButton R_Conductor="@_BankAccount_conductorRef"></R_DeleteButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_CancelButton R_Conductor="@_BankAccount_conductorRef"></R_CancelButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="1">
                        <R_SaveButton R_Conductor="@_BankAccount_conductorRef"></R_SaveButton>
                    </R_ItemLayout>
                </R_StackLayout>


                <R_Conductor @ref="@_BankAccount_conductorRef"
                             R_ViewModel="@_BankAccount_viewModel"
                             R_ConductorParent="_Genereal_conductorRef"
                             R_ServiceGetRecord="@BankAccount_ServiceGetRecord"
                             R_SetAdd="@BankAccount_SetAdd"
                             R_SetEdit="@BankAccount_SetEdit"
                             R_Validation="@BankAccount_Validation"
                             R_ServiceSave="@BankAccount_ServiceSave"
                             R_ServiceDelete="@BankAccount_ServiceDelete">
                </R_Conductor>
            </R_TabStripTab>

        </R_TabStrip>
        
    </R_TabStripTab>

    <R_TabStripTab Title="Pinalty" Id="Pinalty" >
        <R_StackLayout Class="mb-4">
            <R_StackLayout Row>
                <R_ItemLayout xs="1">
                    <R_Label Class="fw-bold" FontSize="11">Invoice Group</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="2">
                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_CODE"
                               Enabled="false">
                    </R_TextBox>
                </R_ItemLayout>
                <R_ItemLayout xs="4">
                    <R_TextBox @bind-Value="@_Genereal_viewModel.Data.CINVGRP_NAME"
                               Enabled="false">
                    </R_TextBox>
                </R_ItemLayout>
            </R_StackLayout>
        </R_StackLayout>

        <R_StackLayout>
            <R_StackLayout Row>
                <R_ItemLayout xs="1" Class="d-inline">
                    <R_CheckBox @bind-Value="@_InvPinalty_viewModel.Data.LPENALTY"
                                R_ConductorSource="@_InvPinalty_conductorRef"
                                R_EnableEdit>
                    </R_CheckBox>
                <R_Label>Enable Pinalty</R_Label>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
