@page "/GSM03000" 
@inherits R_Page
@using GSM03000MODEL.ViewModel
@using GSM03000Common.DTOs
@inject R_ILocalizer<GSM03000FrontResources.Resources_Dummy_Class> _localizer

<R_StackLayout Class="mb-4 mt-3">
    <R_StackLayout Row>
        <R_ItemLayout xs="1">
            <R_Label FontColor="Red" Class="fw-bold" FontSize="15">Property</R_Label>
        </R_ItemLayout>

        <R_ItemLayout xs="2">
            <R_DropDownList Data="@Additional_viewModel.PropertyList"
                            @bind-Value="Additional_viewModel.PropertyValueContext"
                            ValueField="@nameof(GSM03000PropertyDTO.CPROPERTY_ID)"
                            TextField="@nameof(GSM03000PropertyDTO.CPROPERTY_NAME)"
                            R_ConductorSource="@Additional_conductorRef" OnChanged="@PropertyDropdown_OnChange">
            </R_DropDownList>
        </R_ItemLayout>
    </R_StackLayout>
</R_StackLayout>

<R_TabStrip @ref="@TabParent" OnActiveTabIndexChanged="@OnActiveTabIndexChanged">
    <R_TabStripTab Title="Additional Charges">
        <R_StackLayout Class="mb-3">
            <R_Grid @ref="@Additional_gridRef"
                    DataSource="@Additional_viewModel.OtherChargeList"
                    R_ConductorSource="@Additional_conductorRef"
                    R_GridType="@R_eGridType.Navigator"
                    Pageable="true"
                    R_ServiceGetListRecord="@Additional_ServiceGetListRecord">
                <R_GridColumns>
                    <R_GridNumericColumn FieldName="CCHARGES_ID" HeaderText="Charges Id"></R_GridNumericColumn>
                    <R_GridTextColumn FieldName="CCHARGES_NAME" HeaderText="Charges Name"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CSTATUS_DESCRIPTION" HeaderText="Status"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CUPDATE_BY" HeaderText="Last Update By"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="DUPDATE_DATE" HeaderText="Last Update Date"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CCREATE_BY" HeaderText="Created By"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="DCREATE_DATE" HeaderText="Created Date"></R_GridTextColumn>
                </R_GridColumns>
            </R_Grid>
        </R_StackLayout>

        <R_StackLayout>
            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Additional Charges Id</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="2">
                    <R_TextBox @ref="@Additional_ChargesIdTextBox"
                               @bind-Value="@Additional_viewModel.Data.CCHARGES_ID"
                               R_ConductorSource="@Additional_conductorRef"
                               R_EnableAdd="true" R_EnableEdit="false"></R_TextBox>
                </R_ItemLayout>
                <R_ItemLayout xs="6">
                    <R_TextBox @bind-Value="@Additional_viewModel.Data.CCHARGES_NAME"
                               R_ConductorSource="@Additional_conductorRef"
                               R_EnableAdd="true" R_EnableEdit="true"></R_TextBox>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Charges Description</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="8">
                    <R_TextArea @bind-Value="@Additional_viewModel.Data.CDESCRIPTION"
                                R_ConductorSource="@Additional_conductorRef"
                                R_EnableAdd="true"
                                R_EnableEdit="true"></R_TextArea>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Status</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="8">
                    <R_RadioGroup Data="@Additional_viewModel.OptionsStatus"
                                  @bind-Value="@Additional_viewModel.Data.CSTATUS"
                                  ValueField="@nameof(RadioModel.Id)"
                                  TextField="@nameof(RadioModel.Text)"
                                  R_ConductorSource="@Additional_conductorRef"
                                  Enabled="false">
                    </R_RadioGroup>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="4">
                    <R_Label FontColor="Red" Class="fw-bold" FontSize="13">GL ACCOUNT SETUP</R_Label>
                    <R_Label>(Valid when GL Journal Link Enable)</R_Label>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>GL Account No*</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="2">
                    <R_TextBox @bind-Value="@Additional_viewModel.Data.CGLACCOUNT_NO"
                               R_ConductorSource="@Additional_conductorRef"
                               Enabled="false"></R_TextBox>
                </R_ItemLayout>
                <R_ItemLayout xs="1">
                    <R_Lookup R_ConductorSource="@Additional_conductorRef" R_Before_Open_Lookup="@Additional_Before_Open_Lookup" R_After_Open_Lookup="@Additional_After_Open_Lookup" R_EnableAdd R_EnableEdit>...</R_Lookup>
                </R_ItemLayout>
                <R_ItemLayout xs="5">
                    <R_TextBox @bind-Value="@Additional_viewModel.Data.CGLACCOUNT_NAME"
                               R_ConductorSource="@Additional_conductorRef"
                               Enabled="false"></R_TextBox>
                </R_ItemLayout>
            </R_StackLayout>
        </R_StackLayout>

        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_StackLayout Row>
                    <R_ItemLayout xs="3">
                        <R_AddButton R_Conductor="@Additional_conductorRef"></R_AddButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_EditButton R_Conductor="@Additional_conductorRef"></R_EditButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_DeleteButton R_Conductor="@Additional_conductorRef"></R_DeleteButton>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_StackLayout Row Class="justify-content-center">
                    <R_ItemLayout xs="3">
                        <R_Popup @ref="@Additional_R_ActiveInActiveBtn" R_Before_Open_Popup="@Additional_R_Before_Open_Popup_ActivateInactive" R_After_Open_Popup="@Additional_R_After_Open_Popup_ActivateInactive">@Additional_lcLabel</R_Popup>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_Button @ref="@Additional_R_PrintBtn">Print</R_Button>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_StackLayout Row Class="justify-content-end">
                    <R_ItemLayout xs="3">
                <R_CancelButton R_Conductor="@Additional_conductorRef"></R_CancelButton>
            </R_ItemLayout>
            <R_ItemLayout xs="3">
                <R_SaveButton R_Conductor="@Additional_conductorRef"></R_SaveButton>
            </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
        </R_StackLayout>

        <R_Conductor @ref="@Additional_conductorRef"
                     R_ViewModel="@Additional_viewModel"
                     R_IsHeader="true"
                     R_ServiceGetRecord="@Additional_ServiceGetRecord"
                     R_ServiceSave="@Additional_ServiceSave"
                     R_ServiceDelete="@Additional_ServiceDelete"
                     R_SetHasData="@Additional_R_SetHasData"
                     R_CheckAdd="@Additional_R_CheckAdd"
                     R_BeforeDelete="@Additional_R_BeforeDelete"
                     R_Display="@Additional_R_Display"
                     R_AfterSave="@Additional_AfterSave"
                     >
        </R_Conductor>

    </R_TabStripTab>

    <R_TabStripTab Title="Deducation Charges">
        <R_StackLayout Class="mb-3">
            <R_Grid @ref="@Deducation_gridRef"
                    DataSource="@Deducation_viewModel.OtherChargeList"
                    R_ConductorSource="@Deducation_conductorRef"
                    R_GridType="@R_eGridType.Navigator"
                    Pageable="true"
                    R_ServiceGetListRecord="@GridDeducation_ServiceGetListRecord">
                <R_GridColumns>
                    <R_GridNumericColumn FieldName="CCHARGES_ID" HeaderText="Charges Id"></R_GridNumericColumn>
                    <R_GridTextColumn FieldName="CCHARGES_NAME" HeaderText="Charges Name"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CSTATUS_DESCRIPTION" HeaderText="Status"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CUPDATE_BY" HeaderText="Last Update By"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="DUPDATE_DATE" HeaderText="Last Update Date"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="CCREATE_BY" HeaderText="Created By"></R_GridTextColumn>
                    <R_GridTextColumn FieldName="DCREATE_DATE" HeaderText="Created Date"></R_GridTextColumn>
                </R_GridColumns>
            </R_Grid>
        </R_StackLayout>

        <R_StackLayout>
            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Additional Charges Id</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="2">
                    <R_TextBox @ref="@Deducation_ChargesIdTextBox"
                               @bind-Value="@Deducation_viewModel.Data.CCHARGES_ID"
                               R_ConductorSource="@Deducation_conductorRef"
                               R_EnableAdd="true" R_EnableEdit="false"></R_TextBox>
                </R_ItemLayout>
                <R_ItemLayout xs="6">
                    <R_TextBox @bind-Value="@Deducation_viewModel.Data.CCHARGES_NAME"
                               R_ConductorSource="@Deducation_conductorRef"
                               R_EnableAdd="true" R_EnableEdit="true"></R_TextBox>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Charges Description</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="8">
                    <R_TextArea @bind-Value="@Deducation_viewModel.Data.CDESCRIPTION"
                                R_ConductorSource="@Deducation_conductorRef"
                                R_EnableAdd="true"
                                R_EnableEdit="true"></R_TextArea>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>Status</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="8">
                    <R_RadioGroup Data="@Deducation_viewModel.OptionsStatus"
                                  @bind-Value="@Deducation_viewModel.Data.CSTATUS"
                                  ValueField="@nameof(RadioModel.Id)"
                                  TextField="@nameof(RadioModel.Text)"
                                  R_ConductorSource="@Deducation_conductorRef"
                                  Enabled="false">
                    </R_RadioGroup>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="4">
                    <R_Label FontColor="Red" Class="fw-bold" FontSize="13">GL ACCOUNT SETUP</R_Label>
                    <R_Label>(Valid when GL Journal Link Enable)</R_Label>
                </R_ItemLayout>
            </R_StackLayout>

            <R_StackLayout Row>
                <R_ItemLayout xs="2">
                    <R_Label>GL Account No*</R_Label>
                </R_ItemLayout>

                <R_ItemLayout xs="2">
                    <R_TextBox @bind-Value="@Deducation_viewModel.Data.CGLACCOUNT_NO"
                               R_ConductorSource="@Deducation_conductorRef"
                               Enabled="false"></R_TextBox>
                </R_ItemLayout>
                <R_ItemLayout xs="1">
                    <R_Lookup R_ConductorSource="@Deducation_conductorRef" R_Before_Open_Lookup="@GridDeducation_Before_Open_Lookup" R_After_Open_Lookup="@GridDeducation_After_Open_Lookup" R_EnableAdd R_EnableEdit>...</R_Lookup>
                </R_ItemLayout>
                <R_ItemLayout xs="5">
                    <R_TextBox @bind-Value="@Deducation_viewModel.Data.CGLACCOUNT_NAME"
                               R_ConductorSource="@Deducation_conductorRef"
                               Enabled="false"></R_TextBox>
                </R_ItemLayout>
            </R_StackLayout>
        </R_StackLayout>

        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_StackLayout Row>
                    <R_ItemLayout xs="3">
                        <R_AddButton R_Conductor="@Deducation_conductorRef"></R_AddButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_EditButton R_Conductor="@Deducation_conductorRef"></R_EditButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_DeleteButton R_Conductor="@Deducation_conductorRef"></R_DeleteButton>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_StackLayout Row Class="justify-content-center">
                    <R_ItemLayout xs="3">
                        <R_Popup @ref="@R_ActiveInActiveBtn" R_Before_Open_Popup="@GridDeducation_R_Before_Open_Popup_ActivateInactive" R_After_Open_Popup="@GridDeducation_R_After_Open_Popup_ActivateInactive">@Deducation_lcLabel</R_Popup>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_Button @ref="@R_PrintBtn">Print</R_Button>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_StackLayout Row Class="justify-content-end">
                    <R_ItemLayout xs="3">
                        <R_CancelButton R_Conductor="@Deducation_conductorRef"></R_CancelButton>
                    </R_ItemLayout>
                    <R_ItemLayout xs="3">
                        <R_SaveButton R_Conductor="@Deducation_conductorRef"></R_SaveButton>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
        </R_StackLayout>

        <R_Conductor @ref="@Deducation_conductorRef"
                     R_ViewModel="@Deducation_viewModel"
                     R_ConductorParent="@Additional_conductorRef"
                     R_ServiceGetRecord="@GridDeducation_ServiceGetRecord"
                     R_ServiceSave="@GridDeducation_ServiceSave"
                     R_ServiceDelete="@GridDeducation_ServiceDelete"
                     R_SetHasData="@GridDeducation_R_SetHasData"
                     R_CheckAdd="@GridDeducation_R_CheckAdd"
                     R_Display="@GridDeducation_R_Display"
                     R_BeforeAdd="@GridDeducation_BeforeAdd"
                     R_BeforeEdit="@GridDeducation_BeforeEdit"
                     >
        </R_Conductor>
    </R_TabStripTab>
</R_TabStrip>

