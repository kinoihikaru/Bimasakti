@inherits R_Page
@using LMM01000COMMON

<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label>Utility Charges ID*</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="3">
        <R_TextBox @bind-Value="@_viewModel.Data.CCHARGES_ID"
                   R_ConductorSource="@_RateGU_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
    <R_ItemLayout xs="5">
        <R_TextBox @bind-Value="@_viewModel.Data.CCHARGES_NAME"
                   R_ConductorSource="@_RateGU_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label>Currency Code</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="2">
        <R_TextBox @bind-Value="@_viewModel.Data.CCURENCY_CODE"
                   R_ConductorSource="@_RateGU_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label FontColor="red" Class="fw-bold">Charges</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="3" Class="bg-success text-center fw-bold">
        <R_Label FontColor="white">Buying Price</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="3" Class="bg-danger text-center fw-bold">
        <R_Label FontColor="white">Selling Price</R_Label>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label>Standing Charges</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="3">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NBUY_STANDING_CHARGE"
                   R_ConductorSource="@_RateGU_conductorRef"
                   R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>
    <R_ItemLayout xs="3">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NSTANDING_CHARGE"
                          R_ConductorSource="@_RateGU_conductorRef"
                          R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>
</R_StackLayout>


<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label>Usage Charges Rate*</R_Label>
        <R_Label>(per month)</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="3">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NBUY_USAGE_CHARGE_RATE"
                          R_ConductorSource="@_RateGU_conductorRef"
                          R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>

    <R_ItemLayout xs="3">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NUSAGE_CHARGE_RATE"
                          R_ConductorSource="@_RateGU_conductorRef"
                          R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>
</R_StackLayout>


<R_StackLayout Row>
    <R_ItemLayout xs="3" Class="d-inline">
        <R_Label>Maintenance Fee</R_Label>
        <R_Label>(per month)</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="3">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NMAINTENANCE_FEE"
                          R_ConductorSource="@_RateGU_conductorRef"
                          R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>

</R_StackLayout>

<R_StackLayout Row="true">
    <R_ItemLayout xs="3">
        <R_Label>Administration Fee (per Month)</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="1" Class="fs-6">
        <R_RadioGroup Data="@_Universal_viewModel.AdminFeeTypeList"
                      @bind-Value="@_viewModel.Data.CADMIN_FEE"
                      ValueField="@nameof(LMM01000UniversalDTO.CCODE)"
                      TextField="@nameof(LMM01000UniversalDTO.CDESCRIPTION)"
                      R_ConductorSource="@_RateGU_conductorRef" R_EnableEdit OnChanged="@RateGU_Admin_OnChange">
        </R_RadioGroup>
    </R_ItemLayout>
    <R_ItemLayout xs="4">
        <R_StackLayout Row Class="mb-4">
            <R_ItemLayout><R_Label></R_Label></R_ItemLayout>
        </R_StackLayout>
        <R_StackLayout Row Class="mb-4">
            <R_ItemLayout xs="6">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NADMIN_FEE_PCT"
                                  R_ConductorSource="@_RateGU_conductorRef"
                                  Min="0" Max="100"
                                  Enabled="@AdminFeePctEnable">
                </R_NumericTextBox>
            </R_ItemLayout>
        </R_StackLayout>
        <R_StackLayout Row>
            <R_ItemLayout xs="6">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NADMIN_FEE_AMT"
                                  R_ConductorSource="@_RateGU_conductorRef"
                                  Min="0" Max="100"
                                  Enabled="@AdminFeeAmtEnable">
                </R_NumericTextBox>
            </R_ItemLayout>
        </R_StackLayout>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="1" Class="d-inline">
        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_TAX"
                    R_ConductorSource="@_RateGU_conductorRef"
                    R_EnableEdit>
        </R_CheckBox>
        <R_Label>Taxable</R_Label>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="3" >
        <R_Label>Administration Fee For</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="2" Class="d-inline">
        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_SC"
                    R_ConductorSource="@_RateGU_conductorRef"
                    R_EnableEdit>
        </R_CheckBox>
        <R_Label>Standing Charges</R_Label>

    </R_ItemLayout>

    <R_ItemLayout xs="2" Class="d-inline">
        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_USAGE"
                    R_ConductorSource="@_RateGU_conductorRef"
                    R_EnableEdit>
        </R_CheckBox>
        <R_Label>Usage</R_Label>

    </R_ItemLayout>

    <R_ItemLayout xs="2" Class="d-inline">
        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_MAINTENANCE"
                    R_ConductorSource="@_RateGU_conductorRef"
                    R_EnableEdit>
        </R_CheckBox>
        <R_Label>Maintenance</R_Label>

    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row="true">
    <R_ItemLayout xs="1">
        <R_EditButton R_Conductor="@_RateGU_conductorRef"></R_EditButton>
    </R_ItemLayout>
    <R_ItemLayout xs="1">
        <R_Button Enabled="@PrintBtnEnable" R_ConductorSource="@_RateGU_conductorRef">Print</R_Button>
    </R_ItemLayout>
    <R_ItemLayout xs="7">
        <R_StackLayout Row="true" Class="justify-content-end">
            <R_ItemLayout xs="1">
                <R_CancelButton R_Conductor="@_RateGU_conductorRef"></R_CancelButton>
            </R_ItemLayout>
            <R_ItemLayout xs="1">
                <R_SaveButton R_Conductor="@_RateGU_conductorRef"></R_SaveButton>
            </R_ItemLayout>
        </R_StackLayout>
    </R_ItemLayout>
</R_StackLayout>

<R_Conductor @ref="@_RateGU_conductorRef"
             R_ViewModel="@_viewModel"
             R_IsHeader="true"
             R_ServiceGetRecord="@RateWG_ServiceGetRecord"
             R_SetHasData="@RateGU_SetHasData"
             R_ServiceSave="@RateGU_ServiceSave"
             R_BeforeCancel="@RateGU_BeforeCancel"
             R_AfterSave="@RateGU_AfterSave"
             >
</R_Conductor>
