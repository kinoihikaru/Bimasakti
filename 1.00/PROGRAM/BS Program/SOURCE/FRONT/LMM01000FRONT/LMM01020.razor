@inherits R_Page
@using LMM01000COMMON

<R_StackLayout Row>
    <R_ItemLayout xs="2">
        <R_Label>Utility Charges ID*</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="3">
        <R_TextBox @bind-Value="@_viewModel.Data.CCHARGES_ID"
                   R_ConductorSource="@_RateWG_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
    <R_ItemLayout xs="5">
        <R_TextBox @bind-Value="@_viewModel.Data.CCHARGES_NAME"
                   R_ConductorSource="@_RateWG_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="2">
        <R_Label>Currency Code</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="2">
        <R_TextBox @bind-Value="@_viewModel.Data.CCURENCY_CODE"
                   R_ConductorSource="@_RateWG_conductorRef"
                   Enabled="false">
        </R_TextBox>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="3">
        <R_Label>Pipe Size</R_Label>
    </R_ItemLayout>
    <R_ItemLayout xs="2">
        <R_NumericTextBox @bind-Value="@_viewModel.Data.NPIPE_SIZE"
                   R_ConductorSource="@_RateWG_conductorRef"
                                R_EnableEdit>
        </R_NumericTextBox>
    </R_ItemLayout>
    <R_ItemLayout xs="1">
        <R_Label> Inch</R_Label>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="2">
        <R_Label FontColor="red" Class="fw-bold">Charges</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="2" Class="bg-success text-center fw-bold">
        <R_Label FontColor="white">Buying Price</R_Label>
    </R_ItemLayout>

    <R_ItemLayout xs="2" Class="bg-danger text-center fw-bold">
        <R_Label FontColor="white">Selling Price</R_Label>
    </R_ItemLayout>
</R_StackLayout>

<R_StackLayout Row>
    <R_ItemLayout xs="6" Class="me-4">
        
        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_Label>Standing Charges</R_Label>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NBUY_STANDING_CHARGE"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                        R_EnableEdit>
                </R_NumericTextBox>
            </R_ItemLayout>
            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NSTANDING_CHARGE"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                        R_EnableEdit>
                </R_NumericTextBox>
            </R_ItemLayout>
        </R_StackLayout>
        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_Label>Usage Rate Mode</R_Label>
            </R_ItemLayout>

            <R_ItemLayout xs="8">
                <R_RadioGroup Data="@_Universal_viewModel.UsageRateModeList"
                              @bind-Value="@_viewModel.Data.CUSAGE_RATE_MODE"
                              ValueField="@nameof(LMM01000UniversalDTO.CCODE)"
                              TextField="@nameof(LMM01000UniversalDTO.CDESCRIPTION)"
                              R_ConductorSource="@_RateWG_conductorRef" R_EnableEdit>
                </R_RadioGroup>
            </R_ItemLayout>
        </R_StackLayout>
        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_Label>Usage Charges Rate*</R_Label>
            </R_ItemLayout>

            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NBUY_USAGE_CHARGE_RATE"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                        R_EnableEdit>
                </R_NumericTextBox>
            </R_ItemLayout>

            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NUSAGE_CHARGE_RATE"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                        R_EnableEdit>
                </R_NumericTextBox>
            </R_ItemLayout>
        </R_StackLayout>

        <R_StackLayout Row>
            <R_ItemLayout xs="4" Class="d-inline">
                <R_CheckBox @bind-Value="@_viewModel.Data.LUSAGE_MIN_CHARGE"
                            R_ConductorSource="@_RateWG_conductorRef"
                            R_EnableEdit>
                </R_CheckBox>
                <R_Label>Usage Minimum Charges</R_Label>
            </R_ItemLayout>

            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NUSAGE_MIN_CHARGE_AMT"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                  Enabled="@_viewModel.Data.LUSAGE_MIN_CHARGE">
                </R_NumericTextBox>
            </R_ItemLayout>

        </R_StackLayout>
        <R_StackLayout Row>
            <R_ItemLayout xs="3" Class="d-inline">
                <R_Label></R_Label>
            </R_ItemLayout>
        </R_StackLayout>
        <R_StackLayout Row>
            <R_ItemLayout xs="4" Class="d-inline">
                <R_Label>Maintenance Fee</R_Label>
                <R_Label>(per month)</R_Label>
            </R_ItemLayout>

            <R_ItemLayout xs="4">
                <R_NumericTextBox @bind-Value="@_viewModel.Data.NMAINTENANCE_FEE"
                                  R_ConductorSource="@_RateWG_conductorRef"
                                        R_EnableEdit>
                </R_NumericTextBox>
            </R_ItemLayout>

        </R_StackLayout>
    </R_ItemLayout>
    <R_ItemLayout xs="6">
        <R_StackLayout Row="true">
            <R_ItemLayout xs="4">
                <R_Label>Administration Fee (per Month)</R_Label>
            </R_ItemLayout>
            <R_ItemLayout xs="3">
                <R_RadioGroup Data="@_Universal_viewModel.AdminFeeTypeList"
                              @bind-Value="@_viewModel.Data.CADMIN_FEE"
                              ValueField="@nameof(LMM01000UniversalDTO.CCODE)"
                              TextField="@nameof(LMM01000UniversalDTO.CDESCRIPTION)"
                              R_ConductorSource="@_RateWG_conductorRef" R_EnableEdit OnChanged="@RateWG_Admin_OnChange">
                </R_RadioGroup>
            </R_ItemLayout>
            <R_ItemLayout xs="6">
                <R_StackLayout Row Class="mb-5">
                    <R_ItemLayout><R_Label></R_Label></R_ItemLayout>
                </R_StackLayout>
                <R_StackLayout Row Class="mb-3">
                    <R_ItemLayout xs="6">
                        <R_NumericTextBox @bind-Value="@_viewModel.Data.NADMIN_FEE_PCT"
                                          R_ConductorSource="@_RateWG_conductorRef"
                                          Min="0" Max="100"
                                          Enabled="@AdminFeePctEnable">
                        </R_NumericTextBox>
                    </R_ItemLayout>
                </R_StackLayout>
                <R_StackLayout Row>
                    <R_ItemLayout xs="6">
                        <R_NumericTextBox @bind-Value="@_viewModel.Data.NADMIN_FEE_AMT"
                                          R_ConductorSource="@_RateWG_conductorRef"
                                          Min="0" Max="100"
                                          Enabled="@AdminFeeAmtEnable">
                        </R_NumericTextBox>
                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
        </R_StackLayout>

        <R_StackLayout Row>
            <R_ItemLayout xs="4" Class="d-inline">
                <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_TAX"
                            R_ConductorSource="@_RateWG_conductorRef"
                            R_EnableEdit>
                </R_CheckBox>
                <R_Label>Taxable</R_Label>
            </R_ItemLayout>
        </R_StackLayout>

        <R_StackLayout Row>
            <R_ItemLayout xs="4">
                <R_Label>Administration Fee For</R_Label>
            </R_ItemLayout>

            <R_ItemLayout xs="4">
                <R_StackLayout Row>
                    <R_ItemLayout xs="12" Class="d-inline">
                        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_SC"
                                    R_ConductorSource="@_RateWG_conductorRef"
                                    R_EnableEdit>
                        </R_CheckBox>
                        <R_Label>Standing Charges</R_Label>
                    </R_ItemLayout>
                </R_StackLayout>
                <R_StackLayout Row>
                    <R_ItemLayout xs="12" Class="d-inline">
                        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_USAGE"
                                    R_ConductorSource="@_RateWG_conductorRef"
                                    R_EnableEdit>
                        </R_CheckBox>
                        <R_Label>Usage</R_Label>

                    </R_ItemLayout>
                </R_StackLayout>
                <R_StackLayout Row>
                    <R_ItemLayout xs="12" Class="d-inline">
                        <R_CheckBox @bind-Value="@_viewModel.Data.LADMIN_FEE_MAINTENANCE"
                                    R_ConductorSource="@_RateWG_conductorRef"
                                    R_EnableEdit>
                        </R_CheckBox>
                        <R_Label>Maintenance</R_Label>

                    </R_ItemLayout>
                </R_StackLayout>
            </R_ItemLayout>
        </R_StackLayout>

    </R_ItemLayout>
</R_StackLayout>




<R_StackLayout Row>
    <R_Grid @ref="@_RateWGDetail_gridRef"
            DataSource="@_viewModel.RateWGDetailList"
            Pageable
            R_ConductorGridSource="@_RateWGDetail_conductorRef"
            R_GridType="@R_eGridType.Batch"
            AllowAddNewRow="@EnableEdit"
            AllowEditRow="@EnableEdit"
            AllowDeleteRow="@EnableEdit"
            R_ServiceGetListRecord="@RateWGDetail_ServiceGetListRecord">
        <R_GridColumns>
            <R_GridNumericColumn FieldName="IUP_TO_USAGE" HeaderText="Usage (kwh)" R_EnableAdd R_EnableEdit></R_GridNumericColumn>
            <R_GridTextColumn FieldName="CUSAGE_DESC" HeaderText="Description" R_EnableAdd R_EnableEdit></R_GridTextColumn>
            <R_GridNumericColumn FieldName="NBUY_USAGE_CHARGE" HeaderText="LWBP Charges" R_EnableAdd R_EnableEdit></R_GridNumericColumn>
            <R_GridNumericColumn FieldName="NUSAGE_CHARGE" HeaderText="WBP Charges" R_EnableAdd R_EnableEdit></R_GridNumericColumn>
        </R_GridColumns>
    </R_Grid>
</R_StackLayout>

<R_StackLayout Row="true">
    <R_ItemLayout xs="1">
        <R_EditButton R_Conductor="@_RateWG_conductorRef"></R_EditButton>
    </R_ItemLayout>
    <R_ItemLayout xs="1">
        <R_Button R_ConductorSource="@_RateWG_conductorRef" Enabled="@PrintBtnEnable">Print</R_Button>
    </R_ItemLayout>
    <R_ItemLayout xs="7">
        <R_StackLayout Row="true" Class="justify-content-end">
            <R_ItemLayout xs="1">
                <R_CancelButton R_Conductor="@_RateWG_conductorRef"></R_CancelButton>
            </R_ItemLayout>
            <R_ItemLayout xs="1">
                <R_SaveButton R_Conductor="@_RateWG_conductorRef"></R_SaveButton>
            </R_ItemLayout>
        </R_StackLayout>
    </R_ItemLayout>
</R_StackLayout>

<R_Conductor @ref="@_RateWG_conductorRef"
             R_ViewModel="@_viewModel"
             R_IsHeader="true"
             R_ServiceGetRecord="@RateWG_ServiceGetRecord"
             R_SetHasData="@RateWG_SetHasData"
             R_ServiceSave="@RateWG_ServiceSave"
             R_SetEdit="@RateWG_SetEdit"
             R_AfterSave="@RateWG_AfterSave"
             R_BeforeEdit="@RateWG_BeforeEdit"
             R_BeforeCancel="@RateWG_BeforeCancel"
             
             >
</R_Conductor>

<R_ConductorGrid @ref="@_RateWGDetail_conductorRef"
             R_ViewModel="@_viewModel"
             R_ConductorParent="@_RateWG_conductorRef"
             R_ServiceGetRecord="@RateWGDetail_ServiceGetRecord"
             R_Saving="@RateWGDetail_Saving"
             R_AfterSave="@RateWGDetail_AfterSave"
             R_ServiceSaveBatch="@RateWGDetail_ServiceSaveBatch"

             >
</R_ConductorGrid>